# agent-spawner — repo-level environment.
# Copy to .env and fill in.  .env is gitignored.
#
# NOTE: the generated agents each have their OWN .env.example inside their
# folder (for per-agent secrets like TELEGRAM_BOT_TOKEN). This file is just
# for the spawner itself: deploy target + shared credentials.

# --- Deploy target ---------------------------------------------------------
# The remote Linux host `just deploy` ships to.
SSH_HOST=                 # e.g. 203.0.113.7   or   agent.example.com
SSH_USER=                 # e.g. ubuntu        (leave blank to probe $USER, ubuntu, root)
SSH_KEY=                  # e.g. ~/.ssh/id_ed25519  (leave blank to auto-discover)
REMOTE_DIR=~/agents       # where agents land on the remote host

# --- Anthropic -------------------------------------------------------------
# Only needed if you're going to register managed agents from this machine.
ANTHROPIC_API_KEY=

# --- SSH behavior ----------------------------------------------------------
# Set to "yes" for strict first-time host checking. Default is "accept-new".
# STRICT_HOST_KEY_CHECKING=accept-new
