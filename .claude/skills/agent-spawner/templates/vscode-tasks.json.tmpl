{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run {{name}} locally",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/agents/{{name}}",
        "env": { "PYTHONUNBUFFERED": "1" }
      },
      "windows": {
        "command": "${workspaceFolder}/.venv/Scripts/python.exe",
        "args": ["local/agent.py"]
      },
      "linux": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["local/agent.py"]
      },
      "osx": {
        "command": "${workspaceFolder}/.venv/bin/python",
        "args": ["local/agent.py"]
      },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "Register {{name}} as managed agent",
      "type": "shell",
      "options": { "cwd": "${workspaceFolder}/agents/{{name}}" },
      "command": "curl",
      "args": [
        "-X", "POST", "https://api.anthropic.com/v1/managed-agents",
        "-H", "Authorization: Bearer ${env:ANTHROPIC_API_KEY}",
        "-H", "anthropic-beta: managed-agents-2026-04-01",
        "-H", "Content-Type: application/json",
        "-d", "@managed/definition.json"
      ],
      "problemMatcher": []
    }
  ]
}
