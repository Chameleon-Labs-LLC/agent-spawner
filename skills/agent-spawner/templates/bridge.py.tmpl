"""
HMAC signing primitive for the bridge between trusted client processes
(orchestrators, hybrid local agents) and remote workers.

This module owns the signing scheme — sha256 over `timestamp.nonce.body_hash`,
HMAC-SHA256 with BRIDGE_HMAC_SECRET. Verification lives on the Worker side.

The same primitive is used in two distinct directions:

  - **orchestrator → worker** (the `orchestrator` agent type): the
    orchestrator drives a managed Anthropic session, receives
    `agent.custom_tool_use` events from the SSE stream, and uses `sign(body)`
    here to dispatch the tool call to the chosen worker host.

  - **hybrid local → managed twin** (the `hybrid` agent type): a local
    Agent SDK process wants to delegate to its managed peer; because the
    Anthropic API does NOT verify your HMAC headers, a hybrid bridge that
    targets `api.anthropic.com` directly is only protected by the API key.
    For real authn between local and a managed peer, route through your
    own verifier proxy (Lambda Function URL, API Gateway, etc.) that owns
    the BRIDGE_HMAC_SECRET and forwards to /v1/sessions/.../events with
    your Anthropic API key. The `delegate()` example below targets
    DELEGATE_URL, which should point at *your* verifier, not Anthropic.
"""
from __future__ import annotations

import hashlib
import hmac
import json
import os
import secrets
import time
from typing import Any

import httpx

DELEGATE_TO = "{{delegate_to}}"
# Set to your verifier proxy URL — NOT api.anthropic.com directly.
# The verifier validates the HMAC, then forwards to /v1/sessions/.../events
# using its own ANTHROPIC_API_KEY.
DELEGATE_URL = os.environ.get("DELEGATE_URL", "{{delegate_url}}")
BRIDGE_HMAC_SECRET = os.environ["BRIDGE_HMAC_SECRET"].encode()


def sign(body: bytes) -> dict[str, str]:
    """Return the three bridge headers for an HMAC-signed POST."""
    ts = str(int(time.time()))
    nonce = secrets.token_hex(16)
    body_hash = hashlib.sha256(body).hexdigest()
    msg = f"{ts}.{nonce}.{body_hash}".encode()
    sig = hmac.new(BRIDGE_HMAC_SECRET, msg, hashlib.sha256).hexdigest()
    return {
        "X-Bridge-Timestamp": ts,
        "X-Bridge-Nonce": nonce,
        "X-Bridge-Signature": sig,
    }


async def delegate(task: str, session_id: str | None = None) -> dict[str, Any]:
    """
    Hybrid example only — calls a verifier proxy that fronts a managed agent.

    For the orchestrator pattern, see orchestrator/orchestrator.py — it uses
    the Anthropic SDK directly (no proxy) and only HMAC-signs the
    orchestrator → worker leg, where verification is under your control.
    """
    headers = {"Content-Type": "application/json"}

    async with httpx.AsyncClient(timeout=120) as client:
        if session_id is None:
            r = await client.post(f"{DELEGATE_URL}/sessions", headers=headers, json={})
            r.raise_for_status()
            session_id = r.json()["id"]

        body = json.dumps({"type": "user_message", "content": task}).encode()
        headers.update(sign(body))

        r = await client.post(
            f"{DELEGATE_URL}/sessions/{session_id}/events",
            headers=headers,
            content=body,
        )
        r.raise_for_status()

        result = {"session_id": session_id, "events": []}
        async with client.stream(
            "GET", f"{DELEGATE_URL}/sessions/{session_id}/stream", headers=headers
        ) as stream:
            async for line in stream.aiter_lines():
                if line.startswith("data: "):
                    result["events"].append(json.loads(line[6:]))
        return result
