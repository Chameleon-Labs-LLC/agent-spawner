[project]
name = "chameleon-{{name}}"
version = "0.1.0"
description = "{{product}} {{type}} agent — {{name}}"
requires-python = ">=3.11"
dependencies = [
  "claude-agent-sdk>=0.1.0",
  "python-dotenv>=1.0.0",
  "httpx>=0.27.0",
{{channel_deps}}
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.uv]
dev-dependencies = [
  "pytest>=8.0",
  "ruff>=0.5.0",
]
