# {{name}} — environment
# Copy to .env and fill in. NEVER commit .env.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Agent ---
AGENT_PIN={{generated_pin}}
AGENT_KILL_PHRASE=emergency stop

# --- Hive mind / audit ---
# Defaults are fine; uncomment to override.
# HIVE_DB=~/.agents/hive.db
# AUDIT_DIR=~/.agents/audit
# AUDIT_LOG_CONTENT=0

# --- Bridge (hybrid agents only) ---
# This MUST match the value on the managed-side verifier.
BRIDGE_HMAC_SECRET={{generated_hmac}}

# --- Managed agent ID (filled in after you POST managed/definition.json) ---
MANAGED_AGENT_ID=

# --- Channels ---
{{channel_env_block}}

# --- Custom exfil patterns (comma-separated regexes) ---
EXFIL_DENY_PATTERNS=
