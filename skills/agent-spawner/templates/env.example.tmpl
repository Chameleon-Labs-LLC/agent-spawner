# {{name}} — environment template
# This file is COMMITTED. The scaffolder also generates a sibling `.env`
# with the real generated PIN and HMAC secret — that one is .gitignored.
# When you set up a new instance, copy or recreate `.env` from this file
# and populate the blanks.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Agent (PIN-locked channels — only relevant if --channels is set) ---
# 8-digit numeric PIN. Pre-generated and written to `.env` by the scaffolder.
AGENT_PIN=
AGENT_KILL_PHRASE=emergency stop

# --- Hive mind / audit ---
# Defaults are fine; uncomment to override.
# HIVE_DB=~/.agents/hive.db
# AUDIT_DIR=~/.agents/audit
# AUDIT_LOG_CONTENT=0

# --- Bridge HMAC secret (hybrid + orchestrator types) ---
# Pre-generated and written to `.env` by the scaffolder.
# This MUST match the value on whatever component verifies it
# (your verifier proxy for hybrid, the worker(s) for orchestrator).
BRIDGE_HMAC_SECRET=

{{managed_env_block}}

# --- Channels ---
{{channel_env_block}}

# --- Custom exfil patterns (comma-separated regexes) ---
EXFIL_DENY_PATTERNS=
